# Copy to .env and adjust — same flow as Supabase's self-hosted
# docker-compose. No CLI, no pre-generated config.toml/templates.toml
# required: wotp-core boots on defaults and applies these on top.

# Image tag — semver ("1.5.1"), major.minor ("1.5"), or major ("1", tracks
# the latest compatible release). See https://github.com/raucheacho/wotp/pkgs/container/wotp
WOTP_VERSION=1

# Port the API + dashboard listen on (host and container use the same port)
WOTP_PORT=54321

# Instance display name / device name used for the whatsmeow session
WOTP_PROJECT_NAME=wotp
WOTP_PROJECT_REF=wotp-default

# Set to false to disable the embedded dashboard
WOTP_ENABLE_DASHBOARD=true

# Optional: pin your own anon/service API keys instead of letting wotp
# generate them on first boot (check `docker compose logs wotp` for the
# generated ones if you leave these blank — they're only printed once).
# WOTP_ANON_KEY=
# WOTP_SERVICE_KEY=
