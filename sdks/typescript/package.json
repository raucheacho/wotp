{
  "name": "wotp-client",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for Wotp — WhatsApp OTP, self-hosted, one command.",
  "author": "Wotp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raucheacho/wotp"
  },
  "keywords": [
    "wotp",
    "otp",
    "whatsapp",
    "verification",
    "sms",
    "2fa",
    "auth"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
